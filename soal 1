        ("BVA-T3",  1,  MID, MID, "Tugas: Minimum+1 (1)",True),
        ("BVA-T4", 99,  MID, MID, "Tugas: Maximum-1 (99)",True),
        ("BVA-T5",100,  MID, MID, "Tugas: Maximum (100)",True),
        ("BVA-T6",101,  MID, MID, "Tugas: Out of Bound atas (101)",False),
    ]

    bva_uts = [
        ("BVA-U1", MID, -1,  MID, "UTS: Out of Bound bawah (-1)",False),
        ("BVA-U2", MID,  0,  MID, "UTS: Minimum (0)",True),
        ("BVA-U3", MID,  1,  MID, "UTS: Minimum+1 (1)",True),
        ("BVA-U4", MID, 99,  MID, "UTS: Maximum-1 (99)",True),
        ("BVA-U5", MID,100,  MID, "UTS: Maximum (100)",True),
        ("BVA-U6", MID,101,  MID, "UTS: Out of Bound atas (101)",False),
    ]

    bva_uas = [
        ("BVA-S1", MID, MID,  -1, "UAS: Out of Bound bawah (-1)",False),
        ("BVA-S2", MID, MID,   0, "UAS: Minimum (0)", True),
        ("BVA-S3", MID, MID,   1, "UAS: Minimum+1 (1)",True),
