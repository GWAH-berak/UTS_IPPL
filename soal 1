def validate_input(value, name: str) -> tuple[bool, str]:
    # Cek tipe data
    if not isinstance(value, (int, float)):
        return False, f"ERROR: {name} harus bertipe numerik (int/float), bukan {type(value).__name__}"
    # Cek NaN atau Infinity
    if isinstance(value, float) and (value != value or abs(value) == float('inf')):
        return False, f"ERROR: {name} tidak boleh NaN atau Infinity"
    # Cek rentang
    if value < 0 or value > 100:
        return False, f"ERROR: {name} ({value}) di luar rentang 0–100"
    return True, f"OK: {name} = {value}"


def hitung_nilai_akhir(tugas: float, uts: float, uas: float) -> Union[float, str]:
    # Validasi semua input
    for val, nama in [(tugas, "Tugas"), (uts, "UTS"), (uas, "UAS")]:
        valid, pesan = validate_input(val, nama)
        if not valid:
            return pesan

    nilai_akhir = (0.30 * tugas) + (0.30 * uts) + (0.40 * uas)
    return round(nilai_akhir, 2)


def tentukan_grade(nilai_akhir) -> str:
    if isinstance(nilai_akhir, str):
        return "INVALID"
    if nilai_akhir < 50:
        return "E"
    elif nilai_akhir < 65:
        return "D"
    elif nilai_akhir < 75:
        return "C"
    elif nilai_akhir < 85:
        return "B"
    else:
        return "A"


def jalankan_test_case(test_id, tugas, uts, uas, deskripsi, expected_valid=True):
    hasil = hitung_nilai_akhir(tugas, uts, uas)
    if isinstance(hasil, str):  # error
        grade = "INVALID"
        status = "INVALID (Error)"
        valid = False
    else:
        grade = tentukan_grade(hasil)
        status = f"VALID → Nilai Akhir = {hasil:.2f}, Grade = {grade}"
        valid = True

    passed = valid == expected_valid
    return {
        "id": test_id,
        "tugas": tugas,
        "uts": uts,
        "uas": uas,
        "deskripsi": deskripsi,
        "hasil": hasil,
        "grade": grade,
        "status": status,
        "expected_valid": expected_valid,
        "passed": passed
    }


def buat_test_bva():
