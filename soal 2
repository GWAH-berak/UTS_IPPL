import matplotlib
matplotlib.use('Agg')
import matplotlib.pyplot as plt
import matplotlib.patches as mpatches
from collections import Counter

def evaluasi_kelulusan(kehadiran: float, nilai_akhir: float, status_bayar: str) -> dict:

    c1_hadir  = kehadiran >= 75       # Kehadiran ≥ 75%
    c2_nilai  = nilai_akhir >= 60     # Nilai Akhir ≥ 60
    c3_bayar  = str(status_bayar).strip().upper() == "LUNAS"

    # Evaluasi rule (prioritas dari atas)
    if not c1_hadir:
        keputusan = "TIDAK LULUS"
        alasan    = "Kehadiran < 75%"
    elif not c3_bayar:
        keputusan = "TIDAK LULUS"
        alasan    = "Pembayaran tidak lunas"
    elif not c2_nilai:
        keputusan = "TIDAK LULUS"
        alasan    = "Nilai Akhir < 60"
    else:
        keputusan = "LULUS"
        alasan    = "Semua syarat terpenuhi"

    return {
        "kehadiran"  : kehadiran,
        "nilai_akhir": nilai_akhir,
        "status_bayar": status_bayar,
        "C1_hadir"   : c1_hadir,
        "C2_nilai"   : c2_nilai,
        "C3_bayar"   : c3_bayar,
        "keputusan"  : keputusan,
        "alasan"     : alasan,
    }

def cetak_decision_table():
    header = f"\n{'='*80}\n DECISION TABLE SISTEM E-LEARNING\n{'='*80}"
    print(header)

    print("""
KONDISI DAN AKSI:
  Conditions (C):
    C1: Kehadiran ≥ 75%        (T=Ya / F=Tidak)
    C2: Nilai Akhir ≥ 60       (T=Ya / F=Tidak)
    C3: Status Pembayaran=Lunas(T=Ya / F=Tidak)

  Actions (A):
    A1: LULUS
    A2: TIDAK LULUS
""")

    print("─"*70)
    print("DECISION TABLE LENGKAP (8 Rules):")
    print("─"*70)
    header_row = f"{'Kondisi/Aksi':<25} | R1  | R2  | R3  | R4  | R5  | R6  | R7  | R8"
    print(header_row)
    print("─"*70)

    rules = [
        # C1    C2    C3
        (True,  True,  True ),   # R1
        (True,  True,  False),   # R2
        (True,  False, True ),   # R3
        (True,  False, False),   # R4
        (False, True,  True ),   # R5
        (False, True,  False),   # R6
        (False, False, True ),   # R7
        (False, False, False),   # R8
    ]

    def sym(val):
        return "  T  " if val else "  F  "

    print(f"{'C1: Kehadiran ≥ 75%':<25} |{'|'.join(sym(r[0]) for r in rules)}")
    print(f"{'C2: Nilai Akhir ≥ 60':<25} |{'|'.join(sym(r[1]) for r in rules)}")
    print(f"{'C3: Status Lunas':<25} |{'|'.join(sym(r[2]) for r in rules)}")
    print("─"*70)

    # Tentukan aksi tiap rule
    def get_aksi(c1, c2, c3):
        if not c1: return "TIDAK"
        if not c3: return "TIDAK"
        if not c2: return "TIDAK"
        return "LULUS"

    aksi_list = [get_aksi(*r) for r in rules]
    print(f"{'A: Keputusan':<25} |{'|'.join(f'  {a:<3}' for a in aksi_list)}")
    print("─"*70)

    print("""
DECISION TABLE DISEDERHANAKAN (Reduced Rules):
  Observasi: R5-R8 semuanya TIDAK LULUS (C1=F mendominasi)
             R2, R3, R4 semuanya TIDAK LULUS (walaupun C1=T)
  → Hanya R1 yang menghasilkan LULUS

┌──────────────────────────┬──────┬──────────────────────────────────────┐
│ Kondisi/Aksi             │  R1  │  R2 (Semua sisa rule)                │
├──────────────────────────┼──────┼──────────────────────────────────────┤
│ C1: Kehadiran ≥ 75%      │  T   │  T/F (jika F → langsung Tidak Lulus)│
│ C2: Nilai Akhir ≥ 60     │  T   │  T/F                                 │
│ C3: Status Lunas         │  T   │  T/F (salah satu F → Tidak Lulus)   │
├──────────────────────────┼──────┼──────────────────────────────────────┤
│ Keputusan                │ LULUS│  TIDAK LULUS                         │
└──────────────────────────┴──────┴──────────────────────────────────────┘

  Kesimpulan: LULUS hanya jika C1 ∧ C2 ∧ C3 = True
              Apabila salah satu kondisi False → TIDAK LULUS
""")


