def buat_test_cases_soal2():
    """
    Test case minimal 6 yang diturunkan dari decision table.
    """
    test_cases = [
        # ID        Kehadiran  Nilai  Bayar         Expected       Deskripsi
        ("TC-01",   80,        70,    "Lunas",       "LULUS",       "R1: Semua syarat terpenuhi → LULUS"),
        ("TC-02",   75,        60,    "Lunas",       "LULUS",       "R1 Batas: Kehadiran=75, Nilai=60, Lunas → LULUS"),
        ("TC-03",   60,        70,    "Lunas",       "TIDAK LULUS", "R5: Kehadiran<75% → TIDAK LULUS"),
        ("TC-04",   80,        70,    "Tidak Lunas", "TIDAK LULUS", "R2: Pembayaran tidak lunas → TIDAK LULUS"),
        ("TC-05",   80,        55,    "Lunas",       "TIDAK LULUS", "R3: Nilai Akhir<60 → TIDAK LULUS"),
        ("TC-06",   74,        59,    "Tidak Lunas", "TIDAK LULUS", "R8: Semua syarat gagal → TIDAK LULUS"),
        ("TC-07",   75,        60,    "Tidak Lunas", "TIDAK LULUS", "Batas kehadiran+nilai, tapi tdk lunas"),
        ("TC-08",  100,       100,    "Lunas",       "LULUS",       "Semua nilai maksimal → LULUS"),
        ("TC-09",   74.9,      60,    "Lunas",       "TIDAK LULUS", "Kehadiran tepat di bawah 75% → TIDAK LULUS"),
        ("TC-10",   75,        59.9,  "Lunas",       "TIDAK LULUS", "Nilai tepat di bawah 60 → TIDAK LULUS"),
    ]

    hasil = []
    for tc_id, kehadiran, nilai, bayar, expected, deskripsi in test_cases:
        r = evaluasi_kelulusan(kehadiran, nilai, bayar)
        passed = r['keputusan'] == expected
        hasil.append({
            "id"        : tc_id,
            "kehadiran" : kehadiran,
            "nilai"     : nilai,
            "bayar"     : bayar,
            "expected"  : expected,
            "actual"    : r['keputusan'],
            "alasan"    : r['alasan'],
            "passed"    : passed,
            "deskripsi" : deskripsi,
        })
    return hasil


def tampilkan_hasil_soal2(test_cases):
    print(f"\n{'='*100}")
    print(" BAGIAN B & C: TEST CASE E-LEARNING - HASIL PENGUJIAN")
    print(f"{'='*100}")
    print(f"{'ID':<8} {'Hadir%':>7} {'Nilai':>7} {'Bayar':<14} {'Expected':<13} {'Actual':<13} {'Pass':>5}  Deskripsi")
    print("-"*100)
    for tc in test_cases:
        p = "✓" if tc['passed'] else "✗"
        print(f"{tc['id']:<8} {tc['kehadiran']:>7} {tc['nilai']:>7} {tc['bayar']:<14} "
              f"{tc['expected']:<13} {tc['actual']:<13} {p:>5}  {tc['deskripsi']}")
    passed = sum(1 for t in test_cases if t['passed'])
    print(f"\n  Total: {len(test_cases)} test | PASS: {passed} | FAIL: {len(test_cases)-passed}")


