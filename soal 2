def buat_grafik_soal2(test_cases):
    import matplotlib.pyplot as plt
    from collections import Counter

    if not test_cases:
        print("Tidak ada data")
        return

    keputusan_list = [tc['actual'] for tc in test_cases]
    lulus     = keputusan_list.count("LULUS")
    tdk_lulus = keputusan_list.count("TIDAK LULUS")

    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    fig.suptitle("Visualisasi Hasil Pengujian - Sistem E-Learning",
                 fontsize=13, fontweight='bold')

    # PIE
    ax1 = axes[0]
    sizes  = [lulus, tdk_lulus]
    labels = [f'LULUS\n({lulus})', f'TIDAK LULUS\n({tdk_lulus})']
    colors = ['#2ecc71', '#e74c3c']

    ax1.pie(sizes, labels=labels, colors=colors,
            autopct='%1.0f%%', startangle=90)
    ax1.set_title("Perbandingan LULUS vs TIDAK LULUS")

    # BAR
    ax2 = axes[1]
    alasan_count = Counter(tc['alasan'] for tc in test_cases)

    ax2.barh(list(alasan_count.keys()), list(alasan_count.values()))
    ax2.set_title("Distribusi Alasan")

    plt.tight_layout()
    plt.savefig("grafik_soal2.png")
    print("Grafik disimpan sebagai grafik_soal2.png")


def analisis_soal2(test_cases):
    print(f"\n{'='*60}")
    print(" ANALISIS HASIL PENGUJIAN SOAL 2")
    print(f"{'='*60}")

    lulus     = sum(1 for t in test_cases if t['actual'] == "LULUS")
    tdk_lulus = sum(1 for t in test_cases if t['actual'] == "TIDAK LULUS")
    print(f"  Total test case : {len(test_cases)}")
    print(f"  LULUS           : {lulus} ({lulus/len(test_cases)*100:.0f}%)")
    print(f"  TIDAK LULUS     : {tdk_lulus} ({tdk_lulus/len(test_cases)*100:.0f}%)")

    # Cek rule coverage
    rules_covered = {
        "R1 (Semua syarat terpenuhi → LULUS)"       : any(t['actual']=="LULUS" for t in test_cases),
        "R2 (Pembayaran tidak lunas → TIDAK LULUS)" : any(t['alasan']=="Pembayaran tidak lunas" for t in test_cases),
        "R3 (Nilai < 60 → TIDAK LULUS)"             : any(t['alasan']=="Nilai Akhir < 60" for t in test_cases),
        "Kehadiran < 75% → TIDAK LULUS"             : any(t['alasan']=="Kehadiran < 75%" for t in test_cases),
        "Semua syarat gagal → TIDAK LULUS"          : any(t['kehadiran']<75 and t['nilai']<60 and t['bayar']!="Lunas"
                                                           for t in test_cases),
    }
    print(f"\n  Rule Coverage:")
    all_covered = True
    for rule, covered in rules_covered.items():
        status = "✓" if covered else "✗"
        print(f"    {status} {rule}")
        if not covered:
            all_covered = False

    if all_covered:
        print("\n  ✓ Semua rule decision table sudah ter-cover oleh test case.")
    else:
        print("\n  ✗ Ada rule yang belum ter-cover. Tambahkan test case.")

    passed = sum(1 for t in test_cases if t['passed'])
    print(f"\n  Hasil Pass/Fail: PASS={passed} | FAIL={len(test_cases)-passed}")
    print("\n  Kesimpulan:")
    print("    Sistem e-learning mengikuti logika konjungtif (AND): LULUS hanya")
    print("    jika ketiga kondisi terpenuhi. Satu kondisi gagal = TIDAK LULUS.")
    print("    Tidak ditemukan anomali pada hasil pengujian.")


